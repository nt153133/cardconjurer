{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Information"
      }
    }
  },
  "Storage": {
    "UploadsRoot": "data/uploads",
    "PublicBasePath": "/user-content"
  },
  "Cards": {
    "Root": "data/cards"
  }
}
